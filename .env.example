# ─── YDB (Managed YDB в Yandex Cloud) ──────────────────────────
# Эндпоинт (без grpcs:// и порта)
YDB_ENDPOINT=ydb.serverless.yandexcloud.net

# Путь к базе данных
YDB_DATABASE=/ru-central1/b1gn0lm957t4js8iqpfi/etn4007vlbls0tt2v37p

# Альтернатива: полная строка подключения (заменяет YDB_ENDPOINT + YDB_DATABASE)
# YDB_CONNECTION_STRING=grpcs://ydb.serverless.yandexcloud.net:2135/?database=/ru-central1/b1gn0lm957t4js8iqpfi/etn4007vlbls0tt2v37p

# ─── Аутентификация ────────────────────────────────────────────
# ВАРИАНТ 1 (РЕКОМЕНДУЕТСЯ): API-ключ сервисного аккаунта Yandex Cloud.
#   Это перманентное решение — API-ключ не протухает и не требует обновления.
#   IamTokenProvider автоматически обменивает его на IAM-токен при каждом запуске
#   и обновляет токен раз в ~11 часов.
#
#   Как получить:
#     1. Создайте сервисный аккаунт в Yandex Cloud
#     2. Выдайте ему роль ydb.editor на нужную БД
#     3. Создайте API-ключ:
#        yc iam api-key create --service-account-name <имя>
#     4. Скопируйте secret из вывода команды
#     5. Установите эту переменную в Vercel Dashboard → Environment Variables
#
# YDB_API_KEY=<ваш_api_ключ_сервисного_аккаунта>

# ВАРИАНТ 2 (устаревший): IAM-токен для локальной разработки.
#   Токен живёт 12 часов и требует регулярного обновления.
#   Получить: yc iam create-token
#   Для Vercel: нужно настроить GitHub Action для автоматического обновления
#   (см. .github/workflows/update-ydb-token.yml)
# YDB_ACCESS_TOKEN_CREDENTIALS=<ваш_iam_токен>