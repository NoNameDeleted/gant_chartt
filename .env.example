# ─── YDB (Managed YDB в Yandex Cloud) ──────────────────────────
# Эндпоинт (без grpcs:// и порта)
YDB_ENDPOINT=ydb.serverless.yandexcloud.net

# Путь к базе данных
YDB_DATABASE=/ru-central1/b1gn0lm957t4js8iqpfi/etn4007vlbls0tt2v37p

# Альтернатива: полная строка подключения (заменяет YDB_ENDPOINT + YDB_DATABASE)
# YDB_CONNECTION_STRING=grpcs://ydb.serverless.yandexcloud.net:2135/?database=/ru-central1/b1gn0lm957t4js8iqpfi/etn4007vlbls0tt2v37p

# ─── Аутентификация ────────────────────────────────────────────
# Приоритет выбора (см. src/lib/server/ydb.js):
#   1. YDB_ACCESS_TOKEN_CREDENTIALS — IAM-токен (не требует доступа к IAM API)
#   2. YDB_SA_KEY_JSON — авторизованный ключ (требует доступа к iam.api.cloud.yandex.net)
#   3. MetadataCredentialsProvider — только внутри Yandex Cloud
#
# ВАРИАНТ 1 (ДЛЯ VERCEL): IAM-токен + GitHub Action для автообновления.
#   IAM-токен живёт 12 часов. GitHub Action обновляет его каждые 11 часов
#   и передеплоит Vercel.
#
#   Настройка:
#     1. Получите IAM-токен: yc iam create-token
#     2. Установите в Vercel: YDB_ACCESS_TOKEN_CREDENTIALS=<токен>
#     3. В GitHub Secrets добавьте:
#        - YC_SA_KEY_JSON — авторизованный ключ сервисного аккаунта
#        - YC_CLOUD_ID — ID облака
#        - YC_FOLDER_ID — ID каталога
#        - VERCEL_TOKEN — токен Vercel
#        - VERCEL_PROJECT_ID — ID проекта Vercel
#     4. GitHub Action (.github/workflows/update-ydb-token.yml) будет
#        автоматически обновлять токен и передеплоить сайт.
#
YDB_ACCESS_TOKEN_CREDENTIALS=

# ВАРИАНТ 2 (ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ): авторизованный ключ сервисного аккаунта.
#   Не протухает. Требует доступа к iam.api.cloud.yandex.net для обмена
#   JWT на IAM-токен.
#
#   Как получить:
#     yc iam key create --service-account-name <имя> --output sa-key.json
#     # Скопируйте содержимое sa-key.json в переменную YDB_SA_KEY_JSON
#
# YDB_SA_KEY_JSON={"id":"...","service_account_id":"...","private_key":"..."}